generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  ACTIVE
  DISABLED
}

enum MembershipRole {
  OWNER
  WRITER
  READER
}

enum ClientType {
  PUBLIC
  CONFIDENTIAL
}

enum RedirectUriType {
  EXACT
  HOST_WILDCARD
  PATH_SUFFIX
  ANY
}

enum KeyStatus {
  ACTIVE
  ROTATED
  REVOKED
}

enum TokenEndpointAuthMethod {
  client_secret_basic
  client_secret_post
  none
}

enum OAuthClientMode {
  regular
  proxy
}

enum ProxyProviderType {
  oidc
  oauth2
}

enum JwtSigningAlg {
  RS256
  PS256
  ES256
  ES384
}

enum LoginStrategy {
  USERNAME
  EMAIL
}

model Tenant {
  id                String              @id @default(uuid())
  name              String
  status            TenantStatus        @default(ACTIVE)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  defaultApiResource   ApiResource?     @relation("TenantDefaultApiResource", fields: [defaultApiResourceId], references: [id])
  defaultApiResourceId String?          @unique
  apiResources       ApiResource[]
  memberships       TenantMembership[]
  invites           Invite[]
  clients           Client[]
  keys              TenantKey[]
  mockUsers         MockUser[]
  mockIdentities    MockIdentity[]
  authorizationCode AuthorizationCode[]
  accessTokens      AccessToken[]
  mockSessions      MockSession[]
  proxyAuthTransactions ProxyAuthTransaction[]
  proxyTokenExchanges   ProxyTokenExchange[]
  proxyAuthorizationCodes ProxyAuthorizationCode[]
}

model ApiResource {
  id          String     @id @default(uuid())
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId    String
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  clients     Client[]
  authorizationCodes AuthorizationCode[]
  accessTokens AccessToken[]
  defaultFor  Tenant?    @relation("TenantDefaultApiResource")
  proxyAuthTransactions ProxyAuthTransaction[]
  proxyTokenExchanges   ProxyTokenExchange[]
  proxyAuthorizationCodes ProxyAuthorizationCode[]

  @@unique([tenantId, name])
}

model AdminUser {
  id          String            @id @default(uuid())
  logtoSub    String?           @unique
  email       String?           @unique
  name        String?
  image       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  memberships TenantMembership[]
  createdInvites Invite[]       @relation("InviteCreatedBy")
  acceptedInvites Invite[]      @relation("InviteUsedBy")
  accounts    Account[]
  sessions    Session[]
  oauthTestSessions OAuthTestSession[]
  @@map("User")
}

model TenantMembership {
  id         String       @id @default(uuid())
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId   String
  adminUser  AdminUser    @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  adminUserId String
  role       MembershipRole @default(READER)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  @@unique([tenantId, adminUserId])
}

model Invite {
  id             String          @id @default(uuid())
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId       String
  role           MembershipRole  @default(READER)
  tokenHash      String          @unique
  expiresAt      DateTime
  usedAt         DateTime?
  usedBy         AdminUser?      @relation("InviteUsedBy", fields: [usedByUserId], references: [id])
  usedByUserId   String?
  revokedAt      DateTime?
  createdBy      AdminUser       @relation("InviteCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdAt      DateTime        @default(now())
  @@index([tenantId])
}

model Client {
  id                       String                   @id @default(uuid())
  tenant                   Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId                 String
  apiResource              ApiResource?             @relation(fields: [apiResourceId], references: [id])
  apiResourceId            String?
  name                     String
  clientId                 String
  clientSecretHash         String?
  clientSecretEncrypted    String?
  clientType               ClientType               @default(CONFIDENTIAL)
  oauthClientMode          OAuthClientMode          @default(regular)
  allowedScopes            String[]                 @default(["openid", "profile", "email"])
  allowedGrantTypes        String[]                 @default(["authorization_code"])
  allowedResponseTypes     String[]                 @default(["code"])
  pkceRequired             Boolean                  @default(true)
  tokenEndpointAuthMethod  TokenEndpointAuthMethod  @default(client_secret_basic)
  idTokenSignedResponseAlg JwtSigningAlg?
  accessTokenSigningAlg    JwtSigningAlg?
  authStrategies           Json                     @default("{\"username\":{\"enabled\":true,\"subSource\":\"entered\"},\"email\":{\"enabled\":false,\"subSource\":\"entered\",\"emailVerifiedMode\":\"false\"}}")
  reauthTtlSeconds         Int                      @default(0)
  redirectUris             RedirectUri[]
  oauthTestSessions        OAuthTestSession[]
  authorizationCodes       AuthorizationCode[]
  accessTokens             AccessToken[]
  proxyConfig              ProxyProviderConfig?
  proxyAuthTransactions    ProxyAuthTransaction[]
  proxyTokenExchanges      ProxyTokenExchange[]
  proxyAuthorizationCodes  ProxyAuthorizationCode[]
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  @@unique([tenantId, clientId])
}

model RedirectUri {
  id        String          @id @default(uuid())
  client    Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  uri       String
  type      RedirectUriType @default(EXACT)
  enabled   Boolean         @default(true)
  createdAt DateTime        @default(now())
  @@unique([clientId, uri])
}

model TenantKey {
  id                   String        @id @default(uuid())
  tenant               Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId             String
  kid                  String
  kty                  String
  alg                  JwtSigningAlg @default(RS256)
  use                  String        @default("sig")
  status               KeyStatus     @default(ACTIVE)
  publicJwk            Json
  privateJwkEncrypted  String
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  @@unique([tenantId, kid])
  @@index([tenantId, alg, status])
}

model MockUser {
  id            String            @id @default(uuid())
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId      String
  username      String
  displayName   String?
  email         String?
  claims        Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  sessions      MockSession[]
  codes         AuthorizationCode[]
  accessTokens  AccessToken[]
  @@unique([tenantId, username])
}

model MockIdentity {
  id          String        @id @default(uuid())
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId    String
  strategy    LoginStrategy
  identifier  String
  sub         String        @unique
  email       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([tenantId, strategy, identifier])
}

model OAuthTestSession {
  id           String   @id @default(uuid())
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId     String
  adminUser    AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  adminUserId  String
  tenantId     String
  codeVerifier String
  redirectUri  String
  scopes       String
  nonce        String?
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([clientId])
  @@index([clientId, adminUserId])
}

model MockSession {
  id               String   @id @default(uuid())
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId         String
  user             MockUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  loginStrategy    LoginStrategy
  subject          String
  emailVerifiedOverride Boolean?
  sessionTokenHash String   @unique
  expiresAt        DateTime
  createdAt        DateTime @default(now())
}

model AuthorizationCode {
  id                 String      @id @default(uuid())
  tenant             Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId           String
  client             Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId           String
  apiResource        ApiResource @relation(fields: [apiResourceId], references: [id], onDelete: Cascade)
  apiResourceId      String
  user               MockUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  loginStrategy      LoginStrategy
  subject            String
  emailVerifiedOverride Boolean?
  codeHash           String      @unique
  redirectUri        String
  scope              String
  nonce              String?
  state              String?
  codeChallenge      String
  codeChallengeMethod String     @default("S256")
  expiresAt          DateTime
  consumedAt         DateTime?
  createdAt          DateTime    @default(now())
  @@index([tenantId, clientId])
}

model ProxyProviderConfig {
  id                          String             @id @default(uuid())
  client                      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId                    String             @unique
  providerType                ProxyProviderType
  authorizationEndpoint       String
  tokenEndpoint               String
  userinfoEndpoint            String?
  jwksUri                     String?
  upstreamClientId            String
  upstreamClientSecretEncrypted String?
  upstreamTokenEndpointAuthMethod TokenEndpointAuthMethod @default(client_secret_basic)
  defaultScopes               String[]           @default([])
  scopeMapping                Json?
  pkceSupported               Boolean            @default(false)
  oidcEnabled                 Boolean            @default(false)
  promptPassthroughEnabled    Boolean            @default(false)
  loginHintPassthroughEnabled Boolean            @default(false)
  passthroughTokenResponse    Boolean            @default(false)
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt
}

model ProxyAuthTransaction {
  id                       String   @id @default(uuid())
  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId                 String
  apiResource              ApiResource @relation(fields: [apiResourceId], references: [id], onDelete: Cascade)
  apiResourceId            String
  client                   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId                 String
  redirectUri              String
  appState                 String?
  appNonce                 String?
  appScope                 String
  appCodeChallenge         String
  appCodeChallengeMethod   String   @default("S256")
  providerScope            String
  providerCodeVerifier     String?
  providerPkceEnabled      Boolean  @default(false)
  prompt                   String?
  loginHint                String?
  createdAt                DateTime @default(now())
  expiresAt                DateTime
  tokenExchange            ProxyTokenExchange? @relation("AuthTransactionExchange")

  @@index([tenantId, clientId])
  @@index([expiresAt])
}

model ProxyTokenExchange {
  id                     String   @id @default(uuid())
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId               String
  apiResource            ApiResource @relation(fields: [apiResourceId], references: [id], onDelete: Cascade)
  apiResourceId          String
  client                 Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId               String
  transaction            ProxyAuthTransaction? @relation("AuthTransactionExchange", fields: [transactionId], references: [id])
  transactionId          String?  @unique
  providerResponseEncrypted String
  createdAt              DateTime @default(now())
  expiresAt              DateTime
  consumedAt             DateTime?
  proxyAuthorizationCode ProxyAuthorizationCode? @relation("ExchangeAuthorizationCode")

  @@index([tenantId, clientId])
  @@index([expiresAt])
}

model ProxyAuthorizationCode {
  id                     String   @id @default(uuid())
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId               String
  apiResource            ApiResource @relation(fields: [apiResourceId], references: [id], onDelete: Cascade)
  apiResourceId          String
  client                 Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId               String
  codeHash               String   @unique
  redirectUri            String
  scope                  String
  nonce                  String?
  state                  String?
  codeChallenge          String
  codeChallengeMethod    String   @default("S256")
  expiresAt              DateTime
  consumedAt             DateTime?
  createdAt              DateTime @default(now())
  tokenExchange          ProxyTokenExchange @relation("ExchangeAuthorizationCode", fields: [tokenExchangeId], references: [id], onDelete: Cascade)
  tokenExchangeId        String   @unique

  @@index([tenantId, clientId])
  @@index([expiresAt])
}

model AccessToken {
  id         String   @id @default(uuid())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId   String
  apiResource ApiResource @relation(fields: [apiResourceId], references: [id], onDelete: Cascade)
  apiResourceId String
  user       MockUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  jti        String   @unique
  scope      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Account {
  id                String    @id @default(uuid())
  user              AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?   @db.Text
  access_token      String?   @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?   @db.Text
  session_state     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  @@unique([provider, providerAccountId])
}

model Session {
  id           String    @id @default(uuid())
  sessionToken String    @unique
  user         AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  expires      DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String    @unique
  expires    DateTime
  createdAt  DateTime  @default(now())
  @@unique([identifier, token])
}
