{
  "name": "mockauth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test:prepare": "dotenv -e .env.test -o -- pnpm prisma migrate reset --force && dotenv -e .env.test -o -- pnpm prisma:seed",
    "test": "pnpm test:prepare && dotenv -e .env.test -o -- vitest run",
    "test:watch": "dotenv -e .env.test -o -- vitest",
    "test:e2e": "pnpm test:prepare && dotenv -e .env.test -o -- playwright test",
    "test:e2e:serial": "node scripts/run-playwright-suite.mjs",
    "test:e2e:ci": "pnpm test:prepare && pnpm test:e2e:serial",
    "test:e2e:dev": "pnpm test:prepare && dotenv -e .env.test -o -- playwright test --headed",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx -r tsconfig-paths/register prisma/seed.ts",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "postinstall": "pnpm prisma:generate",
    "playwright:install": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright install --with-deps"
  },
  "dependencies": {
    "@hookform/resolvers": "3.9.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "7.4.0",
    "@radix-ui/react-alert-dialog": "1.1.1",
    "@radix-ui/react-avatar": "1.1.0",
    "@radix-ui/react-dialog": "1.1.1",
    "@radix-ui/react-label": "2.1.0",
    "@radix-ui/react-popover": "1.1.1",
    "@radix-ui/react-scroll-area": "1.1.0",
    "@radix-ui/react-select": "2.1.2",
    "@radix-ui/react-separator": "1.1.0",
    "@radix-ui/react-slot": "1.1.0",
    "@radix-ui/react-tabs": "1.1.1",
    "@radix-ui/react-toast": "1.2.1",
    "@radix-ui/react-tooltip": "1.1.2",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "cmdk": "1.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "jose": "6.1.3",
    "lucide-react": "0.475.0",
    "nanoid": "5.1.6",
    "next": "16.1.6",
    "next-auth": "4.24.13",
    "next-themes": "0.4.4",
    "pg": "^8.18.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "7.71.1",
    "tailwind-merge": "2.5.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "1.58.2",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@testing-library/user-event": "14.5.2",
    "jsdom": "24.1.3",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "dotenv-cli": "11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "openid-client": "6.8.2",
    "playwright": "1.58.2",
    "postcss": "^8",
    "prisma": "7.4.0",
    "start-server-and-test": "2.1.3",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "1.0.7",
    "tsconfig-paths": "^4.2.0",
    "tsx": "4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "4.0.18"
  },
  "prisma": {
    "seed": "tsx -r tsconfig-paths/register prisma/seed.ts"
  },
  "engines": {
    "node": ">=20.17.0"
  },
  "packageManager": "pnpm@10.29.3"
}
