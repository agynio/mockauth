{
  "name": "mockauth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test:prepare": "dotenv -e .env.test -- pnpm prisma migrate reset --force && dotenv -e .env.test -- pnpm prisma:seed",
    "test": "pnpm test:prepare && dotenv -e .env.test -- vitest run",
    "test:watch": "dotenv -e .env.test -- vitest",
    "test:e2e": "pnpm test:prepare && dotenv -e .env.test -- playwright test",
    "test:e2e:ci": "pnpm test:prepare && dotenv -e .env.test -- playwright test --reporter=line",
    "test:e2e:dev": "pnpm test:prepare && dotenv -e .env.test -- playwright test --headed",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx -r tsconfig-paths/register prisma/seed.ts",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "postinstall": "playwright install --with-deps"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "7.4.0",
    "bcryptjs": "3.0.3",
    "clsx": "2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "jose": "6.1.3",
    "nanoid": "5.1.6",
    "next": "16.1.6",
    "next-auth": "4.24.13",
    "pg": "^8.18.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "7.71.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "1.58.2",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "dotenv-cli": "11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "openid-client": "6.8.2",
    "playwright": "1.58.2",
    "postcss": "^8",
    "prisma": "7.4.0",
    "start-server-and-test": "2.1.3",
    "tailwindcss": "^3.4.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "4.0.18"
  },
  "prisma": {
    "seed": "tsx -r tsconfig-paths/register prisma/seed.ts"
  },
  "engines": {
    "node": ">=20.17.0"
  },
  "packageManager": "pnpm@10.29.3"
}
